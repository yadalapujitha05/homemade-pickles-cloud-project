# =====================================================
# HomeMade Pickles & Snacks – Environment Variables
# Copy this file to .env and fill in your AWS details.
# NEVER commit the real .env file to version control.
# =====================================================

# Flask secret key (change this to a random string in production)
SECRET_KEY=any-random-string-like-abc123xyz

# Password hashing salt (change this too)
PASSWORD_SALT=another-random-string-like-pickles2024
# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_actual_key_id_here
AWS_SECRET_ACCESS_KEY=your_actual_secret_key_here